# Internal working files - never publish
_private/

# Built playbook archives belong in GitHub Releases, not the repo
*.apbx
files.zip

# Redistributable payloads - place locally before packaging, do not commit
Executables/DirectX/
Executables/vcredist_all.exe

# Driver/tool downloads users drop into PostInstall locally - not part of the repo.
# Web shortcuts (.url), NVIDIA profiles, and the profile inspector ARE part of the
# playbook and must ship in the .apbx, so they are tracked.
PostInstall/Drivers/**/*.exe
!PostInstall/Drivers/NVIDIA/Nvidia Settings/nvidiaProfileInspector.exe
PostInstall/Drivers/**/*.msi
PostInstall/Drivers/**/*.zip
PostInstall/tools/*.exe
PostInstall/tools/*.zip

# Local Claude Code settings - not part of the playbook
.claude/
